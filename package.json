    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.3",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
