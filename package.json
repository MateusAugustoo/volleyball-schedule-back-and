{
  "name": "volleyball-schedule",
  "version": "1.0.0",
  "description": "Sistema de agenda de horarios para quadra publica da orla do açude!",
  "license": "ISC",
  "author": "MateusAugustoo",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node --env-file=.env dist/server.js",
